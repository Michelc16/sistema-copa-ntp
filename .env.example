# Conexao copiada no painel do Neon (use a URL com SSL)
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/neondb?sslmode=require

# Conta unica autorizada a alterar o campeonato
ADMIN_EMAIL=admin@copantp.com.br
ADMIN_PASSWORD=troque-por-uma-senha-forte

# Gere valores longos e aleatorios (minimo recomendado: 32 caracteres)
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
SETUP_SECRET=troque-por-outro-segredo-de-configuracao
